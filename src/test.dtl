
int table1_base = 0;
int table2_base = 400;


int t1_c1 = 1;
int t2_c1 = 1;
int t1_c2 = 5;
int t2_c2 = 6;
int t1_c3 = 8;
int t2_c3 = 8;

int t2_arr = {1,6,8};
int t2row_size = 128;
int t1row_size = 64;


for (int x = 0; x < 3; x++)
{
    for (int i = 0; i < 50000; i++)
    {
        switch(x)
        {
            case:
                out = table1_base + t1_c1 + i*t1row_size;
                out = table2_base + t2_arr[x] + i*t2row_size;
            case:
                out = table1_base + t1_c2 + i*t2row_size;
                out = table2_base + t2_arr[x] + i*t2row_size;
            case:
                out = table1_base + t1_c3 + i*t2row_size;
                out = table2_base + t2_arr[x] + i*t2row_size;
        }
    }
}
